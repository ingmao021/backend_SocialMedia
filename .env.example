# ── PostgreSQL ──────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/socialvideo
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ── JWT ─────────────────────────────────────────
# Must be ≥ 32 chars for HMAC-SHA256
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# ── Google OAuth ────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── GCP / Vertex AI ─────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GCS_BUCKET_NAME=your-gcs-bucket
# Pega el JSON de la service account en UNA SOLA LÍNEA.
# Para comprimir: jq -c . service-account-key.json
# IMPORTANTE: en local (.env), private_key debe tener \n LITERALES (backslash+n,
# no saltos de línea reales). En Render, podés pegar el JSON multilínea
# directamente en la UI de Environment Variables.
GCP_SA_KEY_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# ── Vertex AI model ────────────────────────────
VEO_MODEL_ID=veo-3.1-lite-generate-preview

# ── CORS ────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Spring ──────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
PORT=8080
